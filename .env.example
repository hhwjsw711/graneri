# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=
CONVEX_SITE_URL=

OPENAI_API_KEY=

# Client-side Convex URLs for the Vite app
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Public URL for the marketing site metadata
VITE_MARKETING_SITE_URL=
VITE_TERMS_URL=/terms
VITE_PRIVACY_URL=/privacy
VITE_AUTH_PROVIDERS=github,google

# Public GitHub repository used for desktop release lookup and download links
VITE_GITHUB_OWNER=murabcd
VITE_GITHUB_REPO=graneri
VITE_DESKTOP_DOWNLOAD_URL=
VITE_DESKTOP_RELEASE_API_URL=

# Desktop package identity for forked/self-hosted builds
GRANERI_DESKTOP_APP_ID=dev.graneri.desktop
GRANERI_DESKTOP_PRODUCT_NAME=Graneri

# Optional hosted defaults for official packaged desktop builds.
# Leave blank for self-hosted/forked builds so the app requires explicit URLs.
GRANERI_HOSTED_CONVEX_URL=
GRANERI_HOSTED_CONVEX_SITE_URL=
GRANERI_HOSTED_SITE_URL=

# Better Auth runs on the Convex deployment. Set these with `npx convex env set`
BETTER_AUTH_SECRET=

SITE_URL=http://127.0.0.1:3000
SITE_TRUSTED_ORIGINS=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=
