{
  "name": "desktop",
  "productName": "Graneri",
  "version": "0.1.0",
  "description": "Graneri desktop app",
  "author": "Graneri",
  "private": true,
  "type": "module",
  "main": "./src/main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:bundled": "node ./scripts/dev-bundled.mjs",
    "build": "node ./scripts/build.mjs",
    "package:mac:dir": "electron-builder --config electron-builder.config.mjs --mac dir",
    "package:mac": "electron-builder --config electron-builder.config.mjs --mac dmg",
    "package:mac:release": "electron-builder --config electron-builder.config.mjs --mac --publish always",
    "generate:app-icon": "node ./scripts/generate-app-icon.mjs",
    "generate:tray-icons": "electron ./scripts/generate-tray-icons.mjs",
    "lint": "biome lint src scripts electron-builder.config.mjs package.json",
    "lint:fix": "biome lint --write src scripts electron-builder.config.mjs package.json",
    "check": "biome check src scripts electron-builder.config.mjs package.json",
    "check:fix": "biome check --write src scripts electron-builder.config.mjs package.json",
    "format": "biome format --write src scripts electron-builder.config.mjs package.json",
    "test": "node --test tests/*.test.cjs tests/*.test.mjs && node scripts/check-syntax.mjs",
    "typecheck": "node scripts/check-syntax.mjs"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.42",
    "@ai-sdk/openai": "3.0.63",
    "ai": "6.0.182",
    "bash-tool": "^1.3.16",
    "conf": "^15.0.2",
    "convex": "^1.34.0",
    "electron-updater": "^6.6.2",
    "ws": "^8.18.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "web": "workspace:*"
  }
}
